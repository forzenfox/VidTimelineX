#!/usr/bin/env sh
. "$(dirname -- "$0")/_/husky.sh"

# 定义颜色输出
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m' # No Color

echo "🔍 开始代码检查..."

# 1. 运行 lint-staged 进行代码格式化和 ESLint 检查
echo "📝 步骤 1/3: 代码格式化和 ESLint 检查..."
npx lint-staged
if [ $? -ne 0 ]; then
    echo "${RED}❌ 代码检查失败，请修复错误后重新提交${NC}"
    exit 1
fi
echo "${GREEN}✅ 代码格式化检查通过${NC}"

# 2. TypeScript 类型检查（仅在变更文件包含 TypeScript 文件时运行）
echo "🔷 步骤 2/3: TypeScript 类型检查..."
npx tsc --noEmit --project tsconfig.app.json
if [ $? -ne 0 ]; then
    echo "${RED}❌ TypeScript 类型检查失败，请修复类型错误后重新提交${NC}"
    exit 1
fi
echo "${GREEN}✅ TypeScript 类型检查通过${NC}"

# 3. 运行单元测试（针对变更文件）
echo "🧪 步骤 3/3: 运行相关单元测试..."
# 获取变更的 TypeScript/TypeScript React 文件
CHANGED_FILES=$(git diff --cached --name-only --diff-filter=ACM | grep -E '\.(ts|tsx)$' || true)

if [ -n "$CHANGED_FILES" ]; then
    # 尝试查找与变更文件相关的测试并运行
    # 这里简化处理：如果有 src/ 下的文件变更，运行单元测试
    echo "$CHANGED_FILES" | grep -q "^src/"
    if [ $? -eq 0 ]; then
        echo "检测到源代码变更，运行单元测试..."
        # 使用 --findRelatedTests 只运行与变更文件相关的测试
        npx jest --findRelatedTests $CHANGED_FILES --passWithNoTests --silent
        if [ $? -ne 0 ]; then
            echo "${YELLOW}⚠️  部分测试未通过，但允许提交（建议在 CI 中严格执行）${NC}"
        else
            echo "${GREEN}✅ 相关单元测试通过${NC}"
        fi
    else
        echo "${YELLOW}⊘ 跳过单元测试（无源代码变更）${NC}"
    fi
else
    echo "${YELLOW}⊘ 跳过单元测试（无代码文件变更）${NC}"
fi

echo ""
echo "${GREEN}🎉 所有检查通过，准备提交代码${NC}"
exit 0
